# Backend-specific environment variables
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/telegram_saas
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=telegram_saas

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# QPay
QPAY_MERCHANT_ID=your-qpay-merchant-id
QPAY_API_KEY=your-qpay-api-key
QPAY_API_SECRET=your-qpay-api-secret
QPAY_WEBHOOK_SECRET=your-qpay-webhook-secret
QPAY_BASE_URL=https://merchant.qpay.mn/v2

# CORS
FRONTEND_URL=http://localhost:3000

# Telegram
TEST_TELEGRAM_CHANNEL_ID=-1002914754157
TEST_TELEGRAM_CHANNEL_USERNAME=test channel
TELEGRAM_ONBOARDING_BOT_TOKEN=8434724156:AAFSehiiuA8V2SNbH1azn6oKizx8KKP4W1A
TELEGRAM_CHANNEL_ID_BOT_TOKEN=8098859177:AAHM_SG4dvjLlKbil7fHG_emMEWzRUVNI7k

# Logging Configuration
LOG_LEVEL=info
LOG_DIR=logs
LOG_REQUEST_BODIES=false
LOG_DB_QUERIES=false

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX_REQUESTS=100

# Bot Token Encryption
ENCRYPTION_KEY=your-encryption-key-minimum-32-characters-long

# Base URL for webhooks (used for Telegram webhook auto-generation)
BASE_URL=https://3d58615f67fc.ngrok-free.app

# Webhook Health Check Configuration
# Enable webhook health check on application startup (default: true)
WEBHOOK_HEALTH_CHECK_ON_STARTUP=true

# Auto-fix mismatched webhooks on startup (default: true)
# This automatically updates webhooks when BASE_URL changes (e.g., new ngrok tunnel)
# Set to false if you want to manually review mismatches before fixing
WEBHOOK_AUTO_FIX_ON_STARTUP=true

# Verify webhooks with Telegram API during health check (default: false)
# WARNING: This makes API calls to Telegram and may hit rate limits
# NOTE: Also fails with ngrok free plan due to browser authentication requirements
# Set to true only if using a paid ngrok plan or a public domain
WEBHOOK_VERIFY_WITH_TELEGRAM=false