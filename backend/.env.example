# Backend-specific environment variables
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/telegram_saas
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=telegram_saas

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# QPay
QPAY_MERCHANT_ID=your-qpay-merchant-id
QPAY_API_KEY=your-qpay-api-key
QPAY_API_SECRET=your-qpay-api-secret
QPAY_WEBHOOK_SECRET=your-qpay-webhook-secret
QPAY_BASE_URL=https://merchant.qpay.mn/v2

# CORS
FRONTEND_URL=http://localhost:3000

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhooks/telegram

# Telegram Testing Configuration (for development and E2E tests)
TEST_TELEGRAM_BOT_TOKEN=your-test-bot-token
TEST_TELEGRAM_CHANNEL_ID=your-test-channel-id
TEST_TELEGRAM_CHAT_ID=your-test-chat-id

# Logging Configuration
LOG_LEVEL=info
LOG_DIR=logs
LOG_REQUEST_BODIES=false
LOG_DB_QUERIES=false

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Bot Token Encryption
ENCRYPTION_KEY=your-encryption-key-minimum-32-characters-long

# Base URL for webhooks
BASE_URL=https://your-domain.com