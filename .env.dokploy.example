# =============================================================================
# Dokploy Environment — paste into Dokploy → Compose service → Environment tab
# =============================================================================
# Replace yourdomain.com with your real domain. Generate secrets with:
#   openssl rand -base64 32
# NEVER commit the filled-in version.
# =============================================================================

# --- Domains (must be subdomains under your wildcard record) -----------------
APP_DOMAIN=app.yourdomain.com          # frontend
API_DOMAIN=api.yourdomain.com          # backend (API + QPay/Telegram webhooks)

# --- Database ----------------------------------------------------------------
DB_NAME=telegram_saas
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Redis -------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- JWT ---------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_32+_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_32+_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- QPay --------------------------------------------------------------------
QPAY_USERNAME=your_qpay_username
QPAY_PASSWORD=your_qpay_password
QPAY_TERMINAL_ID=your_terminal_id
QPAY_BASE_URL=https://quickqr.qpay.mn
QPAY_WEBHOOK_SECRET=CHANGE_ME_32+_CHARS
QPAY_ENV=production
# NOTE: QPAY_CALLBACK_BASE_URL + BASE_URL are derived from API_DOMAIN in compose.

# --- Telegram bot tokens (from @BotFather) -----------------------------------
TELEGRAM_ONBOARDING_BOT_TOKEN=your_onboarding_bot_token
TELEGRAM_CHANNEL_ID_BOT_TOKEN=your_channel_id_bot_token

# --- Encryption --------------------------------------------------------------
ENCRYPTION_KEY=CHANGE_ME_32+_CHARS

# --- Logging / rate limiting -------------------------------------------------
LOG_LEVEL=info
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX_REQUESTS=100

# --- Webhook self-check ------------------------------------------------------
WEBHOOK_HEALTH_CHECK_ON_STARTUP=true
WEBHOOK_AUTO_FIX_ON_STARTUP=true

# --- Frontend public flags ---------------------------------------------------
NEXT_PUBLIC_APP_NAME=Telegram Groups SaaS
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_SENTRY_DSN=

# --- Worker cron (optional overrides) ----------------------------------------
MEMBERSHIP_CHECK_CRON=0 * * * *
ANALYTICS_CRON=0 */6 * * *
CLEANUP_CRON=0 2 * * *
