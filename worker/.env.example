# Worker-specific environment variables
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=telegram_saas

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Job Configuration
MAX_JOB_ATTEMPTS=3
JOB_BACKOFF_TYPE=exponential
JOB_BACKOFF_DELAY=2000

# Scheduling
MEMBERSHIP_CHECK_CRON=0 * * * *
ANALYTICS_CRON=0 */6 * * *
CLEANUP_CRON=0 2 * * *

# Logging
LOG_LEVEL=info
LOG_DIR=./logs