# =============================================================================
# TELEGRAM GROUPS SAAS - PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.production and fill in your production values
# NEVER commit .env.production to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
DB_NAME=telegram_saas
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_PORT=5432

# -----------------------------------------------------------------------------
# REDIS CONFIGURATION
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------
# Generate strong secrets using: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_JWT_SECRET_MINIMUM_32_CHARACTERS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MINIMUM_32_CHARACTERS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# QPAY PAYMENT GATEWAY
# -----------------------------------------------------------------------------
# Get credentials from QPay merchant dashboard: https://merchant.qpay.mn
QPAY_USERNAME=your_production_qpay_username
QPAY_PASSWORD=your_production_qpay_password
QPAY_TERMINAL_ID=your_terminal_id
QPAY_BASE_URL=https://quickqr.qpay.mn
QPAY_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET_MINIMUM_32_CHARACTERS
QPAY_CALLBACK_BASE_URL=https://yourdomain.com
QPAY_ENV=production

# -----------------------------------------------------------------------------
# APPLICATION URLS
# -----------------------------------------------------------------------------
FRONTEND_URL=https://yourdomain.com
BASE_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# -----------------------------------------------------------------------------
# TELEGRAM BOT TOKENS
# -----------------------------------------------------------------------------
# Get bot tokens from @BotFather on Telegram
TELEGRAM_ONBOARDING_BOT_TOKEN=your_onboarding_bot_token
TELEGRAM_CHANNEL_ID_BOT_TOKEN=your_channel_id_bot_token

# -----------------------------------------------------------------------------
# LOGGING CONFIGURATION
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_REQUEST_BODIES=false
LOG_DB_QUERIES=false

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# ENCRYPTION
# -----------------------------------------------------------------------------
# Generate using: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY_MINIMUM_32_CHARACTERS

# -----------------------------------------------------------------------------
# WEBHOOK CONFIGURATION
# -----------------------------------------------------------------------------
WEBHOOK_HEALTH_CHECK_ON_STARTUP=true
WEBHOOK_AUTO_FIX_ON_STARTUP=true

# -----------------------------------------------------------------------------
# FRONTEND CONFIGURATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Telegram Groups SaaS"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_if_using_sentry

# -----------------------------------------------------------------------------
# SERVICE PORTS (Internal Docker Network)
# -----------------------------------------------------------------------------
BACKEND_PORT=3001
FRONTEND_PORT=3000

# -----------------------------------------------------------------------------
# DATA DIRECTORY (For bind mounts)
# -----------------------------------------------------------------------------
# Directory where persistent data will be stored (postgres, redis, logs, cache)
# Use absolute path for production: /var/lib/telegram-saas
# Default: ./data (relative to project root)
DATA_DIR=./data

# =============================================================================
# SECURITY CHECKLIST
# =============================================================================
# [ ] Changed all default passwords
# [ ] Generated strong JWT secrets (minimum 32 characters)
# [ ] Generated strong encryption key
# [ ] Configured production QPay credentials
# [ ] Updated FRONTEND_URL and BASE_URL to your domain
# [ ] Configured SSL certificates in nginx/ssl/
# [ ] Set up firewall rules (only expose ports 80, 443)
# [ ] Enabled log rotation
# [ ] Configured backup strategy for postgres_data volume
# [ ] Set up monitoring and alerting
# [ ] Reviewed and updated rate limiting settings
# =============================================================================